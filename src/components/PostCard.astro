---  
import { Image } from "astro:assets";
import dayjs from "@utils/dayjs";
import { DATE_FORMAT, t } from "@config";
import type { PostData } from "@interfaces/data";
import Heading from "./widgets/Heading.astro";
import PostStats from "./widgets/PostStats.astro";
import Card from "./temple/Card.astro";
import { Icon } from "astro-icon/components";  
  
const {  
  title,  
  image,  
  pubDate,  
  description,  
  badge,  
  categories = [],  
  tags = [],  
  word = "0",  
  time = "0",  
  url = decodeURIComponent(Astro.url.toString()),  
} = Astro.props as PostData;  
  
const displayDate = pubDate ? dayjs(pubDate).format(DATE_FORMAT) : "";  
---  
  
<Card class="overflow-hidden">
  <div class="flex flex-col w-full">
    <!-- Image Section -->  
    {  
      image && (  
        <a href={url} class="relative w-full aspect-video overflow-hidden group">  
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 z-10 transition-all duration-300 flex items-center justify-center">  
            <Icon  
              name="lucide:arrow-right"  
              class="w-12 h-12 text-white opacity-0 group-hover:opacity-100 transition-all duration-300 transform group-hover:translate-x-2"  
            />  
          </div>  
          <Image  
            src={image}  
            alt={title}  
            width={800}  
            height={400}  
            format="webp"  
            loading="lazy"  
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"  
          />  
        </a>  
      )  
    }  

    <!-- Content Section -->
    <div class="p-4 overflow-hidden flex flex-col">
      <div class="mb-3">
        <Heading url={url} title={title}>{title}</Heading> 
      </div>
      
      <div class="grid grid-cols-2 gap-x-3 gap-y-1 text-sm text-base-content/70 mb-3 opacity-75">
        {
          pubDate && (
            <span class="flex items-center gap-1">
              <Icon name="lucide:calendar" class="h-4 w-4 flex-shrink-0" />
              <span class="truncate">{displayDate}</span>
            </span>
          )
        }
        <div class="flex items-center gap-1">
          <Icon name="lucide:book-open" class="h-4 w-4 flex-shrink-0" />
          <span class="truncate">{word} {t("label.wordCount")} · {time} {t("label.readTime")}</span>
        </div>
        {
          badge && (
            <span class="flex items-center gap-1">
              <Icon name="lucide:bookmark" class="h-4 w-4 flex-shrink-0" />
              <span class="truncate">{badge}</span>
            </span>
          )
        }
        <PostStats url={url} />
      </div>

      <p class="text-sm text-base-content/70 mb-4">{description}</p>  
      
      <!-- Categories and Tags Section -->
      <div class="flex flex-wrap gap-2">
        {categories && categories.length > 0 && categories.map((category) => (
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-medium transition-all duration-300 hover:bg-primary/20" data-category={category}>
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 6a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z" />
            </svg>
            {category}
          </span>
        ))}
        {tags && tags.length > 0 && tags.map((tag) => (
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-secondary/10 text-secondary text-xs font-medium transition-all duration-300 hover:bg-secondary/20" data-tag={tag}>
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 3a1 1 0 00-1.447-.894L8.763 6H5a3 3 0 000 6h.28l1.771 5.316A1 1 0 008 18h1a1 1 0 001-1v-4h5a1 1 0 00.707-.293l2.828-2.829a1 1 0 000-1.415l-2.828-2.828A1 1 0 0018 3zm-6 10H9v2H7v-2H2a1 1 0 01-1-1V8a1 1 0 011-1h3.586l1.707-1.707A1 1 0 018 4h6a1 1 0 011 1v5h-2z" clip-rule="evenodd" />
            </svg>
            {tag}
          </span>
        ))}
      </div>
    </div>  
  </div>  
</Card>